{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "glsl",
      "camelcase": "Glsl",
      "scope": "source.glsl",
      "path": ".",
      "file-types": [
        "vert",
        "frag",
        "vsh",
        "fsh",
        "glsl"
      ]
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "GLSL grammar for tree-sitter",
    "authors": [
      {
        "name": "Tin Švagelj",
        "email": "tin.svagelj@live.com"
      }
    ],
    "links": {
      "repository": "https://github.com/Caellian/tree-sitter-glsl"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
